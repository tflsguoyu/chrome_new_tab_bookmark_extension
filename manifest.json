{
  "manifest_version": 3,
  "name": "Metro Bookmarks",
  "version": "1.0.2",
  "description": "A local Metro-style bookmark wall.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "bookmarks",
    "favicon"
  ],
  "chrome_url_overrides": {
    "newtab": "metro_bookmarks.html"
  }
}
